TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# openai | ollama
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_TRANSCRIBE_BASE_URL=
OPENAI_TRANSCRIBE_PROXY=
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=qwen2.5:7b
SYSTEM_PROMPT=Ты полезный русскоязычный ассистент. Отвечай понятно и по делу.
MAX_HISTORY_MESSAGES=20

# Ограничение доступа: список Telegram user_id через запятую.
# Пусто = доступ открыт всем.
ALLOWED_TELEGRAM_USER_IDS=

# История: memory | redis | postgres
HISTORY_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
POSTGRES_DSN=dbname=telegram_bot user=telegram_bot password=telegram_bot host=127.0.0.1 port=5432

# Режим запуска Telegram: polling | webhook
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_URL=https://your-domain.com
WEBHOOK_LISTEN=127.0.0.1
WEBHOOK_PORT=8080
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_SECRET_TOKEN=change_me_long_random_string

# Прокси для доступа к Telegram API (если есть блокировка сети).
# Пример: http://user:password@host:port
TELEGRAM_PROXY=

# Прокси для OpenAI API (если регионально блокируется api.openai.com).
# Пример: socks5://user:password@host:port
OPENAI_PROXY=

# Необязательно: кастомный совместимый endpoint (например, прокси-шлюз).
OPENAI_BASE_URL=

# Логирование в файл (с ротацией).
LOG_FILE=logs/bot.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=3
